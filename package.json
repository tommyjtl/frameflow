{
  "name": "frameflow",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "web",
    "server"
  ],
  "scripts": {
    "dev": "bun run dev:server & bun run dev:web",
    "dev:web": "bun run --cwd web dev",
    "dev:server": "bun run --cwd server dev",
    "build": "bun run --cwd web build",
    "lint": "bun run --cwd web lint",
    "start:server": "bun run --cwd server start"
  }
}
